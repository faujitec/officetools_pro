# AdMob is configured in lib/constants.dart and native manifests.
# Optional overrides via --dart-define (e.g. for staging):
#
#   flutter run --dart-define=ADS_IN_DEBUG=true
#   flutter run --dart-define=ADMOB_BANNER_IOS=ca-app-pub-xxx/banner
#   flutter run --dart-define=ADMOB_INTERSTITIAL_IOS=ca-app-pub-xxx/interstitial
#
# Release Android app id override (default is already set in build.gradle.kts):
#   flutter build appbundle --release -PADMOB_APP_ID=ca-app-pub-xxx~yyyy
#
# Never commit real keys outside the repo policy you use for AdMob IDs.
